---
interface Servicio {
  icon: string;
  titulo: string;
  descripcion: string;
}

const servicios: Servicio[] = [
  {
    icon: "🏢",
    titulo: "Constitución de SAC",
    descripcion: "Sociedad Anónima Cerrada ideal para negocios con socios. Responsabilidad limitada y estructura flexible para crecer."
  },
  {
    icon: "🤝",
    titulo: "Constitución de SRL",
    descripcion: "Sociedad de Responsabilidad Limitada, perfecta para pequeñas empresas."
  },
  {
    icon: "📋",
    titulo: "RUC y SUNAT",
    descripcion: "Gestión completa de inscripción en SUNAT, obtención de RUC y régimen tributario."
  },
  {
    icon: "📝",
    titulo: "Licencias y Permisos",
    descripcion: "Tramitamos la licencia de funcionamiento municipal y permisos sectoriales."
  },
  {
    icon: "💼",
    titulo: "Asesoría Legal Continua",
    descripcion: "Acompañamiento jurídico permanente para contratos, estatutos y consultas."
  },
  {
    icon: "📊",
    titulo: "Contabilidad Inicial",
    descripcion: "Configuración de libros contables, cuenta bancaria y planificación básica."
  }
];
---

<section id="servicios" class="servicios">
  <div class="section-glow"></div>
  
  <div class="container relative">
    <div class="section-header">
      <span class="tag">Áreas de Práctica</span>
      <h2>Soluciones integrales para<br />tu nueva empresa</h2>
      <p>Nos encargamos de toda la burocracia legal y administrativa. Tú solo concéntrate en hacer crecer tu negocio.</p>
    </div>

    <div class="grid">
      {servicios.map((s) => (
        <div class="card">
          <div class="card-glow"></div>
          <div class="card-content">
            <div class="icon-box">
              <span class="card-icon">{s.icon}</span>
            </div>
            <h3>{s.titulo}</h3>
            <p>{s.descripcion}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .servicios {
    position: relative;
    background: var(--navy-mid);
    overflow: hidden;
  }

  .section-glow {
    position: absolute;
    top: 0; left: 50%;
    transform: translateX(-50%);
    width: 100%;
    height: 1px;
    background: linear-gradient(90deg, transparent, rgba(46, 204, 113, 0.3), transparent);
  }

  .relative { position: relative; z-index: 1; }

  .section-header {
    text-align: center;
    margin-bottom: 4rem;
  }

  .tag {
    display: inline-block;
    color: var(--green-text);
    background: rgba(46, 204, 113, 0.1);
    padding: 0.3rem 1rem;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.2rem;
  }

  .section-header h2 {
    font-size: clamp(2rem, 4vw, 2.8rem);
    color: var(--white);
    margin-bottom: 1.2rem;
  }

  .section-header p {
    color: var(--gray);
    max-width: 540px;
    margin: 0 auto;
    font-size: 1.05rem;
  }

  .grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 1.8rem;
  }

  .card {
    position: relative;
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 16px;
    padding: 2.5rem 2rem;
    overflow: hidden;
    transition: all 0.4s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .card-glow {
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background: radial-gradient(circle at 50% 0%, rgba(46, 204, 113, 0.08), transparent 70%);
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .card-content {
    position: relative;
    z-index: 1;
  }

  .card:hover {
    transform: translateY(-5px);
    border-color: rgba(46, 204, 113, 0.3);
    background: rgba(255, 255, 255, 0.03);
    box-shadow: 0 10px 30px -10px rgba(0, 0, 0, 0.5);
  }

  .card:hover .card-glow {
    opacity: 1;
  }

  .icon-box {
    width: 56px;
    height: 56px;
    background: rgba(46, 204, 113, 0.1);
    border: 1px solid rgba(46, 204, 113, 0.2);
    border-radius: 14px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 1.5rem;
    transition: transform 0.3s ease;
  }

  .card:hover .icon-box {
    transform: scale(1.05) rotate(-3deg);
    background: rgba(46, 204, 113, 0.15);
  }

  .card-icon {
    font-size: 1.8rem;
    line-height: 1;
  }

  .card h3 {
    font-size: 1.25rem;
    font-weight: 600;
    color: var(--white);
    margin-bottom: 0.8rem;
  }

  .card p {
    font-size: 0.95rem;
    color: var(--gray);
    line-height: 1.6;
    margin-bottom: 0;
  }
</style>