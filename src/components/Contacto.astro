---
const whatsappNum: string = "51944541475";
const whatsappMsg: string = encodeURIComponent("Hola, quiero constituir mi empresa. ¿Me pueden orientar?");
const whatsappUrl: string = `https://wa.me/${whatsappNum}?text=${whatsappMsg}`;
---

<section id="contacto" class="contacto">
  <div class="container">
    <div class="cta-box">
      <div class="cta-glow glow-top"></div>
      <div class="cta-glow glow-bottom"></div>
      
      <div class="cta-content">
        <span class="tag">¿Listo para empezar?</span>
        <h2>Constituyamos tu empresa<br />hoy mismo</h2>
        <p>
          Escríbenos por WhatsApp y recibe una consulta gratuita. Nuestros asesores están disponibles de lunes a sábado.
        </p>
        <div class="cta-actions">
          <a href={whatsappUrl} target="_blank" rel="noopener noreferrer" class="btn btn-primary btn-wa">
            <svg aria-hidden="true" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.123.555 4.116 1.528 5.845L.057 23.882a.5.5 0 0 0 .614.622l6.198-1.63A11.94 11.94 0 0 0 12 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 22a9.955 9.955 0 0 1-5.089-1.391l-.361-.214-3.742.984.998-3.648-.235-.374A9.955 9.955 0 0 1 2 12C2 6.477 6.477 2 12 2s10 4.477 10 10-4.477 10-10 10z"/>
            </svg>
            Escribir por WhatsApp
          </a>
          <a href="mailto:contacto@sacsmype.pe" class="btn btn-outline">
            contacto@sacsmype.pe
          </a>
        </div>
        <p class="disclaimer">Consulta inicial completamente gratuita y sin compromiso.</p>
      </div>
    </div>
  </div>
</section>

<style>
  .contacto { 
    position: relative;
    padding: 2rem 0 8rem;
    background: var(--navy);
  }

  .cta-box {
    position: relative;
    background: rgba(17, 34, 64, 0.6);
    border: 1px solid rgba(46, 204, 113, 0.2);
    border-radius: 24px;
    padding: 5rem 3rem;
    text-align: center;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
  }

  .cta-content {
    position: relative;
    z-index: 2;
  }

  .cta-glow {
    position: absolute;
    width: 300px; 
    height: 300px;
    background: radial-gradient(circle, rgba(46,204,113,0.15), transparent 70%);
    pointer-events: none;
    z-index: 1;
  }

  .glow-top {
    top: -150px; 
    left: 10%;
  }

  .glow-bottom {
    bottom: -150px; 
    right: 10%;
  }

  .tag {
    display: inline-block;
    color: var(--green-text);
    background: rgba(46, 204, 113, 0.1);
    padding: 0.3rem 1rem;
    border-radius: 99px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 1.5rem;
  }

  h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    color: var(--white);
    margin-bottom: 1.2rem;
  }

  p {
    color: var(--gray);
    max-width: 500px;
    margin: 0 auto 2.5rem;
    font-size: 1.05rem;
  }

  .cta-actions {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .btn-wa {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .disclaimer {
    font-size: 0.85rem;
    color: #aeb8cc;
    margin-bottom: 0;
  }
</style>